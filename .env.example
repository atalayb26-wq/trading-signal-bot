# TradingView webhook doğrulaması için. Pine Script input'undaki secret ile aynı olmalı.
WEBHOOK_SECRET=change-me-tradingview-secret

# Admin endpointleri için. /telegram/test, /summary/send-now ve /signals/latest bunu ister.
ADMIN_TOKEN=change-me-admin-token

# Telegram BotFather'dan aldığın token.
TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token

# Kanal username'i (@kanaladi) veya numeric chat id (-100...)
# Bot kanala admin olarak eklenmiş olmalı.
TELEGRAM_CHAT_ID=@replace_with_your_channel

APP_TIMEZONE=Europe/Istanbul

# Günlük özet saati
ENABLE_DAILY_SUMMARY=true
REPORT_HOUR=09
REPORT_MINUTE=00

DATABASE_PATH=./data/signals.sqlite3

# İlk gelen sinyalde de Telegram uyarısı atılsın mı?
# false: ilk kayıt sadece DB'ye yazılır; sonraki değişimler Telegram'a gider.
NOTIFY_ON_FIRST_SIGNAL=false

# Snapshot mesajları Telegram'a spam olmasın diye false kalsın.
NOTIFY_ON_BAR_CLOSE_SNAPSHOT=false
